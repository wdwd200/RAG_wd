# Copy this file to .env, then fill in your API key.
# China / Beijing endpoint:
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Required for Qwen embedding and chat calls.
DASHSCOPE_API_KEY=

# Stable official example model. You can override with any model available in
# your DashScope/Bailian workspace, such as qwen-plus-latest or qwen3.6-plus.
QWEN_CHAT_MODEL=qwen-plus

# text-embedding-v4 supports 2048, 1536, 1024, 768, 512, 256, 128, 64.
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024
QWEN_EMBEDDING_BATCH_SIZE=10

QWEN_TEMPERATURE=0.2
QWEN_MAX_TOKENS=1500
QWEN_TIMEOUT_SECONDS=60
RAG_CONTEXT_MAX_CHARS=6000
